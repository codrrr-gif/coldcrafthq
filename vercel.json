{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/verify",  "schedule": "* * * * *" },
    { "path": "/api/cron/verify2", "schedule": "* * * * *" },
    { "path": "/api/cron/verify3", "schedule": "* * * * *" },
    { "path": "/api/cron/verify4", "schedule": "* * * * *" },
    { "path": "/api/cron/verify5", "schedule": "* * * * *" },
    { "path": "/api/cron/weekly-report", "schedule": "0 13 * * 1" },
    { "path": "/api/cron/monthly-report", "schedule": "0 13 1 * *" },
    { "path": "/api/cron/churn-detection", "schedule": "0 14 * * *" },
    { "path": "/api/pipeline/ingest", "schedule": "0 10,15,20 * * 1-5" },
    { "path": "/api/pipeline/check",  "schedule": "*/30 10-22 * * 1-5" },
    { "path": "/api/cron/process-pipeline", "schedule": "*/5 8-23 * * 1-5" },
    { "path": "/api/cron/auto-send",  "schedule": "*/10 * * * 1-5" },
    { "path": "/api/cron/ab-evaluate", "schedule": "0 15 * * 5" }
  ]
}
