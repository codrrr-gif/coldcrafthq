# ColdCraft HQ Environment Variables

# Cal.com embed URL (used on /book page)
# NEXT_PUBLIC_CAL_EMBED_URL=https://cal.com/your-username/strategy-call

# ============================================
# ColdCraft Reply Engine
# ============================================

# Instantly.ai — Email platform
INSTANTLY_API_KEY=

# Anthropic — AI categorization & reply drafting
ANTHROPIC_API_KEY=

# OpenAI — Embeddings for knowledge base vector search
OPENAI_API_KEY=

# Perplexity — Real-time lead research (optional)
PERPLEXITY_API_KEY=

# Supabase — Database & vector store
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook Security (optional — set a random string)
WEBHOOK_SECRET=

# Slack Notifications (create incoming webhook at https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# Cron secret (uses WEBHOOK_SECRET if not set)
CRON_SECRET=

# Apify (signal scraping)
APIFY_API_KEY=

# ICP configuration (comma-separated, optional — defaults are sensible)
ICP_TARGET_TITLES=CEO,Founder,VP Sales,VP of Sales,Head of Sales,CRO,VP Marketing,CMO,Head of Growth
ICP_EXCLUDE_INDUSTRIES=government,non-profit,education
ICP_GEOGRAPHIES=US,United States,UK,Canada,Australia
ICP_MIN_FUNDING_M=0.5
ICP_MAX_FUNDING_M=100
MIN_SIGNAL_SCORE=55

# Campaign mapping (Instantly campaign IDs per signal type)
CAMPAIGN_ID_FUNDING=
CAMPAIGN_ID_JOB_POSTING=
CAMPAIGN_ID_LEADERSHIP=
CAMPAIGN_ID_NEWS=
CAMPAIGN_ID_DEFAULT=
