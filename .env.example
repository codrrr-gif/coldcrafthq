# ColdCraft HQ Environment Variables

# ============================================
# Core Infrastructure
# ============================================

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ============================================
# Email Outreach
# ============================================

# Instantly.ai — primary + secondary key for round-robin throughput
INSTANTLY_API_KEY=
INSTANTLY_API_KEY_2=

# Campaign routing (Instantly campaign IDs per signal type)
CAMPAIGN_ID_FUNDING=
CAMPAIGN_ID_JOB_POSTING=
CAMPAIGN_ID_LEADERSHIP=
CAMPAIGN_ID_NEWS=
CAMPAIGN_ID_DEFAULT=

# ============================================
# AI / LLM
# ============================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ============================================
# Email Finding & Verification
# ============================================

# FindyMail — finds email by name + domain (step 0 before SMTP)
FINDYMAIL_API_KEY=

# MillionVerifier — bulk verification for catch-all / unknown
MILLIONVERIFIER_API_KEY=

# Reacher VPS — SMTP mailbox verification
REACHER_API_URL=https://verify.coldcrafthq.com
REACHER_API_KEY=

# ============================================
# Signal Scraping
# ============================================

APIFY_API_KEY=

# ICP configuration (comma-separated)
ICP_TARGET_TITLES=CEO,Founder,VP Sales,VP of Sales,Head of Sales,CRO,VP Marketing,CMO,Head of Growth
ICP_EXCLUDE_INDUSTRIES=government,non-profit,education
ICP_GEOGRAPHIES=US,United States,UK,Canada,Australia
ICP_MIN_FUNDING_M=0.5
ICP_MAX_FUNDING_M=100
MIN_SIGNAL_SCORE=55

# TAM discovery
ICP_DISCOVERY_KEYWORDS=B2B lead generation,cold email agency,outbound sales,sales development,go-to-market
COMPETITOR_G2_URLS=https://www.g2.com/products/seamless-ai/reviews,https://www.g2.com/products/apollo-io/reviews,https://www.g2.com/products/reply-io/reviews
COMPETITOR_TOOLS=Apollo,Seamless,Reply.io,Outreach,Salesloft,ZoomInfo,Lusha

# ============================================
# CRM
# ============================================

CLOSE_CRM_API_KEY=

# ============================================
# Notifications
# ============================================

SLACK_WEBHOOK_URL=

# ============================================
# Dashboard Auth (NextAuth)
# ============================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Your login credentials
AUTH_EMAIL=
AUTH_PASSWORD=

# ============================================
# Security
# ============================================

WEBHOOK_SECRET=
CRON_SECRET=
CALENDLY_SIGNING_SECRET=

